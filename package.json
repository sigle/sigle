{
  "name": "root",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm changeset publish",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "version": "pnpm changeset version && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "lefthook": "2.1.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "syncpack": "14.0.0",
    "turbo": "2.8.10"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.2"
}
