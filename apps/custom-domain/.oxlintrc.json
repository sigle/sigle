{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["nextjs", "typescript"],
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "perf": "error",
    "restriction": "allow"
  },
  "ignorePatterns": [".next/**", "out/**", "build/**", "next-env.d.ts"],
  "rules": {
    "no-undef": "off"
  }
}
