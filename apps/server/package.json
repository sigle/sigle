{
  "name": "@sigle/server",
  "private": true,
  "scripts": {
    "build": "nitro build",
    "db:generate": "dotenvx run --env-file=.env.development -- prisma generate",
    "db:migrate:prod": "prisma migrate deploy",
    "dev": "dotenvx run --env-file=.env.development --env-file=.env.development.local -- nitro dev --port 3001",
    "prisma:migrate:dev": "dotenvx run --env-file=.env.development -- prisma migrate dev",
    "prisma:studio:dev": "dotenvx run --env-file=.env.development -- prisma studio",
    "check-types": "tsc --noEmit",
    "test": "dotenvx run --env-file=.env.test -- vitest"
  },
  "dependencies": {
    "@ardrive/turbo-sdk": "1.41.0",
    "@dotenvx/dotenvx": "1.54.1",
    "@hirosystems/chainhook-client": "2.4.0",
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@sentry/node": "10.42.0",
    "@sigle/sdk": "workspace:*",
    "@stacks/blockchain-api-client": "8.14.1",
    "@stacks/network": "7.3.1",
    "@stacks/transactions": "7.3.1",
    "@storacha/client": "1.7.9",
    "@t3-oss/env-core": "0.13.10",
    "@ucanto/principal": "9.0.3",
    "better-auth": "1.3.7",
    "better-result": "2.7.0",
    "blurhash": "2.0.5",
    "consola": "3.4.2",
    "multiformats": "13.4.2",
    "nitro-cors": "0.7.1",
    "pg-boss": "10.3.2",
    "posthog-node": "5.28.1",
    "prisma": "7.4.2",
    "rate-limiter-flexible": "7.2.0",
    "rou3": "0.8.1",
    "sharp": "0.34.5",
    "sign-in-with-stacks": "0.1.6",
    "zod": "4.3.6",
    "zod-validation-error": "5.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.3.16",
    "nitro": "3.0.260311-beta",
    "pglite-prisma-adapter": "0.7.2",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.30.2"
}
