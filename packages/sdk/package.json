{
  "name": "@sigle/sdk",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "codegen": "openapi-typescript http://localhost:3001/_openapi.json --output ./src/__generated__/sigle-api-openapi.ts",
    "test": "vitest",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@sigle/contracts-source": "workspace:*",
    "zod-validation-error": "5.0.0"
  },
  "devDependencies": {
    "@stacks/connect": "8.2.6",
    "@stacks/network": "7.3.1",
    "@stacks/transactions": "7.3.1",
    "@tsconfig/recommended": "1.0.13",
    "@types/node": "24.10.12",
    "openapi-typescript": "7.13.0",
    "tsdown": "0.21.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@stacks/connect": "^8.0.0",
    "@stacks/network": "^7.0.0",
    "@stacks/transactions": "^7.0.0",
    "zod": "^4.0.0"
  }
}
